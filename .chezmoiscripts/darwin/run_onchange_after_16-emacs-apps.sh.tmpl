#!/bin/bash
# -*- mode: sh; lexical-binding: t; -*-
# Create Emacs .app wrappers for Alfred (Extra, Org, Dev)
# All are independent standalone Emacs processes
# hash: {{ include "private_dot_config/doom/config.el" | sha256sum }}

EMACS="/Applications/Emacs.app/Contents/MacOS/Emacs"

[ ! -f "$EMACS" ] && exit 0

echo "🔧 Installing Emacs app wrappers..."

for name in Extra Org Dev; do
    mkdir -p "/Applications/Emacs ${name}.app/Contents/MacOS"
    cat > "/Applications/Emacs ${name}.app/Contents/MacOS/Emacs ${name}" << INNER
#!/bin/bash
$EMACS "\$@" &
INNER
    chmod +x "/Applications/Emacs ${name}.app/Contents/MacOS/Emacs ${name}"
done

echo "✅ Emacs Extra.app, Emacs Org.app and Emacs Dev.app installed"
