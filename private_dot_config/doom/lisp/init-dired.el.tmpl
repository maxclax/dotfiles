;;; init-dired.el -*- mode: emacs-lisp; lexical-binding: t; -*-

(defun my/dirvish-dual-panel (&optional use-project)
  "Open two dired panels side by side at the current file's directory.
With prefix argument USE-PROJECT, open at the project root instead."
  (interactive "P")
  (let ((dir (if use-project
                 (or (and (fboundp 'projectile-project-root) (projectile-project-root))
                     (and (fboundp 'project-root) (when-let (p (project-current)) (project-root p)))
                     default-directory)
               default-directory)))
    (delete-other-windows)
    (dired dir)
    (split-window-right)
    (other-window 1)
    (dired dir)
    (other-window 1)))

;; Use the other dired window as default copy/move target (dual-panel behaviour)
(setq dired-dwim-target t)

(defvar my/dired-detailed-view nil
  "Global flag: when non-nil all dired buffers show detailed view.")

(defun my/dired-apply-view-state ()
  "Apply the global view state to the current dired buffer."
  (if my/dired-detailed-view
      (dired-hide-details-mode -1)
    (dired-hide-details-mode 1)))

(add-hook 'dired-mode-hook #'my/dired-apply-view-state)

(defun my/dired-toggle-details ()
  "Toggle between clean and detailed view globally (persists across directories)."
  (interactive)
  (setq my/dired-detailed-view (not my/dired-detailed-view))
  (when (boundp 'dirvish-attributes)
    (setq dirvish-attributes
          (if my/dired-detailed-view
              '(nerd-icons collapse file-size file-time vc-state)
            '(nerd-icons collapse))))
  (my/dired-apply-view-state)
  (dired-revert)
  (message "Dired: %s view" (if my/dired-detailed-view "detailed" "clean")))

;; Auto-switch workspace when opening a file from a different project via dirvish
(defun my/maybe-switch-workspace-for-project (orig-fn &rest args)
  "If file belongs to a different project, open it in that project's workspace.
The file is opened in a new workspace; the current workspace stays untouched."
  (let* ((file (or (car args) (dired-get-filename nil t)))
         (file-dir (and file (file-name-directory (expand-file-name file))))
         (current-root (ignore-errors (projectile-project-root)))
         (file-root (and file-dir
                         (ignore-errors
                           (let ((default-directory file-dir))
                             (projectile-project-root))))))
    (if (and current-root file-root
             (not (string= current-root file-root)))
        ;; Different project — open in its own workspace, stay in current one
        (let* ((project-name (file-name-nondirectory (directory-file-name file-root)))
               (current-ws (+workspace-current-name)))
          (unless (+workspace-exists-p project-name)
            (+workspace/new project-name))
          (+workspace/switch-to project-name)
          (apply orig-fn args)
          (+workspace/switch-to current-ws))
      (apply orig-fn args))))

(advice-add 'dired-find-file :around #'my/maybe-switch-workspace-for-project)

(after! dirvish
  ;; Enable dirvish globally for all dired buffers
  (dirvish-override-dired-mode)

  ;; GNU ls (Nix coreutils) supports --group-directories-first; BSD ls does not.
  ;; Set after dirvish-override-dired-mode so dirvish doesn't reset it.
  (setq dired-listing-switches "-aBhl --group-directories-first")

  ;; Clean by default: icons + subtree only, ls detail columns hidden
  (setq dirvish-attributes '(nerd-icons collapse))

  (setq dirvish-quick-access-entries
        `(("h" "~/" "Home")
          ("c" "~/.config" "config")
          ("l" "~/.local" "local")
          ("d" "~/Desktop" "Desktop")
          ("D" "~/Downloads" "Downloads")
          ("I" ,(expand-file-name "~/icloud/Downloads") "Downloads (iCloud)")
          ("o" ,(expand-file-name {{ .org_dir | quote }}) "Org dir")

          ("w" ,(expand-file-name {{ .workspace | quote }}) "Workspace")
          ("W" ,(expand-file-name {{ .workspace_extra | quote }}) "Workspace extra")
          ("p" ,(expand-file-name {{ .playground | quote }}) "Playground")
          ("r" ,(expand-file-name {{ .resources | quote }}) "Resources")
          ("s" ,(expand-file-name {{ .managed_sync | quote }}) "Managed Sync")

          ;; Add storage entries
          ("P" ,(expand-file-name {{ .primary_storage | quote }}) "Primary Storage")
          ("S" ,(expand-file-name {{ .secondary_storage | quote }}) "Secondary Storage")))

  (when (executable-find "lla")
    (dirvish-define-preview lla (file)
      "Use `lla' to generate directory preview."
      :require ("lla")
      (when (file-directory-p file)
        `(shell . ("lla" "--icons" ,file))))

    (add-to-list 'dirvish-preview-dispatchers 'lla))

  (defun dirvish-copy-file-relative-path (&optional multi-line)
    "Copy filepath of marked files.
    If MULTI-LINE, make every path occupy a new line."
    (interactive "P")
    (let* ((files (mapcar (lambda (file)
                            (file-relative-name (file-local-name file)))
                          (dired-get-marked-files)))
           (names (mapconcat #'concat files (if multi-line "\n" " "))))
      (dirvish--kill-and-echo (if multi-line (concat "\n" names) names)))))
