[general]

# Fast reload
live_config_reload = true

# New windows inherit working directory
ipc_socket = true

{{ if eq .chezmoi.os "darwin" }}
# Thema
import = [
	"~/.config/alacritty/themes/themes/tokyo-night.toml"
]
{{ end }}

[env]
TERM = "xterm-256color"

[window]
decorations = "none"
dynamic_padding = true
opacity = 0.9

[window.padding]
x = 2
y = 2

{{ if (.fontsEnabled) }}

[font]
size = 14.0

[font.normal]
family = "Berkeley Mono"
style = "Regular"

[font.bold]
family = "Berkeley Mono"
style = "Heavy"

[font.bold_italic]
family = "Berkeley Mono"
style = "Heavy Italic"

[font.italic]
family = "Berkeley Mono"
style = "Medium Italic"

{{ end }}

# Claude terminal setup
[[keyboard.bindings]]
key = "Return"
mods = "Shift"
chars = "\u001b\r"

# Send proper escape sequence for Alt+W (M-w in Emacs/tmux)
[[keyboard.bindings]]
key = "W"
mods = "Alt"
chars = "\u001bw"

# New window
[[keyboard.bindings]]
key = "N"
mods = "Control|Shift"
action = "CreateNewWindow"

# Font size
[[keyboard.bindings]]
key = "="
mods = "Control"
action = "IncreaseFontSize"

[[keyboard.bindings]]
key = "-"
mods = "Control"
action = "DecreaseFontSize"

[[keyboard.bindings]]
key = "0"
mods = "Control"
action = "ResetFontSize"

# Emacs-style clipboard: select auto-copies, C-y pastes
[selection]
save_to_clipboard = true

[[keyboard.bindings]]
key = "Y"
mods = "Control"
action = "Paste"
