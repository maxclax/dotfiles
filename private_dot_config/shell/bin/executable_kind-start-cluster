#!/bin/bash -e

# Check if the Podman machine is running
machine_status=$(podman machine ls --format '{{.Name}} {{.Running}}' 2>/dev/null | grep 'podman-machine-default')

if [[ $machine_status == *"false"* ]]; then
  podman machine start >/dev/null
  echo "Starting the Podman machine..."
elif [[ $machine_status == *"true"* ]]; then
  echo "Podman machine is already running."
else
  echo "Podman machine podman-machine-default not found."
fi

# Start all kind containers that are in exited state
kind_containers=$(podman ps --all --filter "name=kind-" --filter "status=exited" --format '{{.Names}}' 2>/dev/null)

if [ -n "$kind_containers" ]; then
  for container in $kind_containers; do
    podman start "$container" >/dev/null
    echo "Starting $container..."
  done
else
  echo "All kind containers are already running or do not exist."
fi
